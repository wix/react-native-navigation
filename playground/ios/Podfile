require 'json'

# RN 0.85+ ships React-Core as a prebuilt XCFramework by default
# (RCT_USE_PREBUILT_RNCORE=1). The download has been flaky and produces
# "missing VFS artifacts" errors during pod install. Force source build
# on RN 85+ unless the env var is explicitly set by the caller.
rn_pkg_path = File.expand_path('../../node_modules/react-native/package.json', __dir__)
if File.exist?(rn_pkg_path)
  rn_version = JSON.parse(File.read(rn_pkg_path))['version']
  rn_minor = rn_version.split('.')[1].to_i
  if rn_minor >= 85 && ENV['RCT_USE_PREBUILT_RNCORE'].nil?
    ENV['RCT_USE_PREBUILT_RNCORE'] = '0'
    Pod::UI.puts "RNN: forcing RCT_USE_PREBUILT_RNCORE=0 for RN #{rn_version}".yellow
  end
end

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'playground' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  pod 'HMSegmentedControl'

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # Add Folly compiler flags to aggregate targets (app targets)
    # This is needed because Folly headers check for FOLLY_CFG_NO_COROUTINES to disable coroutines
    folly_compiler_flags = folly_flags()
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.xcconfigs.each do |config_name, config_file|
        current_flags = config_file.attributes['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
        config_file.attributes['OTHER_CPLUSPLUSFLAGS'] = "#{current_flags} #{folly_compiler_flags}"
        xcconfig_path = aggregate_target.xcconfig_path(config_name)
        config_file.save_as(xcconfig_path)
      end
    end
  end
end

target 'NavigationTests' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  pod 'OCMock'
end

